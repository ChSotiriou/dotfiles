set shell zsh
set shellopts '-eu'

set icons
set previewer ~/.config/lf/preview
set cleaner ~/.config/lf/cleaner
set preview
set ratios 1:2:3

set drawbox true
set icons true
set ignorecase true

set promptfmt "\033[32m➜  \033[36m%w \033[1;35m\033[0m"

cmd open ${{
    case $(xdg-mime query filetype $f) in
        text/csv) devour xdg-open "$f";;
        text/*|application/json) $EDITOR "$f";;
        *) devour xdg-open "$f" ;;
    esac

    lf -remote "send $id reload"
    lf -remote "send $id on-cd"
}}

cmd openNewWindow ${{
    case $(xdg-mime query filetype $f) in
        text/*|application/json) $EDITOR "$f";;
        *) xdg-open "$f" &> /dev/null & ;;
    esac

    lf -remote "send $id reload"
    lf -remote "send $id on-cd"
}}

cmd mkdir %{{
    printf "Directory Name: "
    read ans
    mkdir $ans

    lf -remote "send $id reload"
    lf -remote "send $id on-cd"
}}

cmd mkfile ${{
    clear
    printf "Filename: "
    read ans
    $EDITOR $ans

    lf -remote "send $id reload"
    lf -remote "send $id on-cd"
}}

cmd vimv ${{
    args=""
    while read -r line; do
        args="$args $(basename $line)"
    done < <(echo $fx)

    echo $args | xargs vimv
}}

cmd copy_cwd &{{
   pwd | tr -d '\n' | xsel -b
}}

cmd cd_clip &{{
    new_path="$(xsel -b)"
    lf -remote "send $id cd \"$new_path\""
}}

cmd fzf_jump ${{
    res="$(find . -maxdepth 3 | fzf --reverse --header='Jump to location')"
    if [ -f "$res" ]; then
      cmd="select"
    elif [ -d "$res" ]; then
      cmd="cd"
    fi
    lf -remote "send $id $cmd \"$res\""
}}

cmd fzf_config ${{
    res="$HOME/.config/$(/bin/ls $HOME/.config | fzf --reverse --header='Jump to config')"
    echo $res
    if [ -f "$res" ]; then
      cmd="select"
    elif [ -d "$res" ]; then
      cmd="cd"
    fi
    lf -remote "send $id $cmd \"$res\""
}}

cmd dragon %echo $fx | xargs -d '\n' dragon-drag-and-drop -a -x
cmd dragon-stay %dragon-drag-and-drop -a $fx
cmd dragon-individual %dragon-drag-and-drop $fx
cmd cpdragon %cpdragon
cmd mvdragon %mvdragon
cmd dlfile %dlfile

cmd on-cd &{{
    # display git repository status in your prompt
    source /usr/share/git/completion/git-prompt.sh
    GIT_PS1_SHOWDIRTYSTATE=auto
    GIT_PS1_SHOWSTASHSTATE=auto
    GIT_PS1_SHOWUNTRACKEDFILES=auto
    GIT_PS1_SHOWUPSTREAM=auto
    GIT_PS1_COMPRESSSPARSESTATE=auto
    git=$(__git_ps1 " \ue0a0 %s]") || true
    fmt="\033[32m➜  \033[36m%w \033[1;35m$git\033[0m"
    lf -remote "send $id set promptfmt \"$fmt\""
}}

# git commands
cmd git-status ${{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
        git -c color.status=always status | less -R
        lf -remote "send $id reload"
    fi
}}

cmd git-log ${{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
        git log --color=always --decorate=full | less -R
        lf -remote "send $id reload"
    fi
}}

cmd git-branch ${{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
 	branches=$(git branch -a | sed "s/^..//g")
	choice=$(echo $branches | fzf)
	git checkout $choice
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
    fi
}}

cmd git-add %{{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
        echo $fx | xargs -d '\n' git add
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
        lf -remote "send $id unselect"
        printf "Staged Selected Changes"
    fi
}}

cmd git-merge ${{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
 	branches=$(git branch | sed "s/^..//g")
	choice=$(echo $branches | fzf)
	git merge $choice
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
    fi
}}

cmd git-restore-staged %{{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
        echo $fx | xargs -d '\n' git restore --staged
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
        lf -remote "send $id unselect"
        printf "Restored Changes"
    fi
}}

cmd git-restore %{{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
        echo $fx | xargs -d '\n' git restore
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
        lf -remote "send $id unselect"
        printf "Restored Changes"
    fi
}}

cmd git-commit-message %{{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
        printf "Commit Message: "
        read message
        git commit -m "$message"
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
        printf "Commited Changes"
    fi
}}

cmd git-clone %{{
    printf "Clone URL: "
    read url
    ERROR=0
    (GIT_TERMINAL_PROMPT=0 git clone "$url" &> /dev/null) || ERROR=1
    if [ $ERROR -eq 1 ]; then
        printf "An Error Has Occured"
    else
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
        printf "Cloned %s" "$url"
    fi
}}

cmd git-commit-no-message %{{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
        git commit
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
        printf "Commited Changes"
    fi
}}

cmd git-push %{{
    if [ $(git rev-parse --is-inside-work-tree 2> /dev/null) ]; then
	git push
        lf -remote "send $id reload"
        lf -remote "send $id on-cd"
        printf "Pushed Changes to remote branch"
    fi
}}

cmd extract %{{
    echo $fx | while read -r line
    do
        case "$line" in
          *.tar.bz2)   tar xjf "$line"   ;;
          *.tar.gz)    tar xzf "$line"   ;;
          *.bz2)       bunzip2 "$line"   ;;
          *.rar)       unrar x "$line"   ;;
          *.gz)        gunzip "$line"    ;;
          *.tar)       tar xf "$line"    ;;
          *.tbz2)      tar xjf "$line"   ;;
          *.tgz)       tar xzf "$line"   ;;
          *.zip)       unzip "$line"     ;;
          *.Z)         uncompress "$line";;
          *.7z)        7z x "$line"      ;;
          *.deb)       ar x "$line"      ;;
          *.tar.xz)    tar xf "$line"    ;;
          *.tar.zst)   tar xf "$line"    ;;
          *)           echo "'"$line"' cannot be extracted via ex()" ;;
        esac
    done
}}

